# Kalshi API credentials
KALSHI_API_KEY_ID=your_key_id_here
KALSHI_PRIVATE_KEY_PATH=/Users/you/.kalshi/private_key.pem
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2
KALSHI_ORDER_URL=https://demo-api.kalshi.co/trade-api/v2

# Edge detection & sizing (example: conservative small-live testing)
EDGE_THRESHOLD=0.07
KELLY_FRACTION=0.08
# Per-signal cap vs bankroll: bet_dollars <= MAX_BET_PCT * bankroll (Kelly also caps).
MAX_BET_PCT=0.04

# Tail-risk filters
MIN_P=0.55
TAIL_P_CUTOFF=0.30
TAIL_EDGE_MULT=2.0

# Execution guardrails (Kalshi book quality / YES line cap)
MIN_LIMIT_PRICE=0.20
MAX_YES_LINE=2.0

# Storage
DB_PATH=data/mlb_tb.db

# Model / evaluation
CV_GAP_DATES=1
EVAL_LINES=0.5,1.5,2.5,3.5
DISTRIBUTION=nbinom
