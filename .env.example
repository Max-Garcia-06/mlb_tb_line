# Kalshi API credentials
KALSHI_API_KEY_ID=your_key_id_here
KALSHI_PRIVATE_KEY_PATH=/Users/you/.kalshi/private_key.pem
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2
KALSHI_ORDER_URL=https://demo-api.kalshi.co/trade-api/v2

# Edge detection & sizing (example: conservative small-live testing)
EDGE_THRESHOLD=0.07
KELLY_FRACTION=0.08
# Per-signal cap vs bankroll: bet_dollars <= MAX_BET_PCT * bankroll (Kelly also caps).
MAX_BET_PCT=0.04

# Tail-risk filters
MIN_P=0.55
TAIL_P_CUTOFF=0.30
TAIL_EDGE_MULT=2.0

# Execution guardrails (Kalshi book quality / YES line cap)
MIN_LIMIT_PRICE=0.20
MAX_YES_LINE=2.0

# Storage
DB_PATH=data/mlb_tb.db
SEASONS=2022,2023,2024,2025,2026
MLB_API_MAX_RETRIES=5
MLB_API_RETRY_SLEEP_SEC=2.0

# Model / evaluation
CV_GAP_DATES=1
EVAL_LINES=0.5,1.5,2.5,3.5
DISTRIBUTION=nbinom
USE_OOF_CALIBRATION=true

# Live scan: only trade games starting within N hours (0 = full pre-game slate; use scan --no-time-window)
SCAN_WITHIN_HOURS=2

# Live risk desk
USE_LIVE_BALANCE=true
DAILY_LOSS_LIMIT_USD=50
MAX_ORDERS_PER_DAY=20
MAX_DAILY_DEPLOYED_USD=25
MAX_OPEN_RESTING_USD=15
MAX_CONTRACTS_PER_GAME=30
MAX_LEGS_PER_PLAYER_DAY=2
RESERVE_RESTING_FROM_BANKROLL=true
AUTO_KILL_ON_RISK_BREACH=true
KILL_SWITCH_PATH=data/KILL_SWITCH
REQUIRE_KALSHI_CREDENTIALS=0

# Backtest
BACKTEST_PIT_TRAIN=true
BACKTEST_PIT_RETRAIN_DAYS=7
BACKTEST_USE_EARLIEST_SNAPSHOT=true
BACKTEST_FILL_MODEL=true

# Segment health (segment-report go/no-go)
SEGMENT_MIN_FILLS=5
SEGMENT_MIN_FILL_RATE=0.25
SEGMENT_MIN_AVG_CLV=0.0
SEGMENT_MIN_ROI_PCT=-5.0
SEGMENT_REPORT_LOOKBACK_DAYS=14

# Fill calibrator preflight (OOF still first at scan when USE_OOF_CALIBRATION=true)
CALIBRATE_MAX_AGE_DAYS=14
REQUIRE_FILL_CALIB_FOR_LIVE=0

# Features / ops
MATERIALIZE_FEATURES_ON_ETL=true
STRUCTURED_LOG=0
